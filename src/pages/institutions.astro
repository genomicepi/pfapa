---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site.config';
import institutionsRaw from '../data/institutions.json';
import type { ResearchInstitution } from '../lib/data-types';

const { conditionDisplayName } = siteConfig;
const base = import.meta.env.BASE_URL;
const institutions = institutionsRaw as ResearchInstitution[];

// Sort by publication count
const sortedInstitutions = [...institutions].sort((a, b) =>
  b.conditionPapersCount - a.conditionPapersCount
);

// Group by country
const byCountry = new Map<string, typeof institutions>();
sortedInstitutions.forEach(inst => {
  const country = inst.country || 'Unknown';
  if (!byCountry.has(country)) {
    byCountry.set(country, []);
  }
  byCountry.get(country)!.push(inst);
});

const countries = Array.from(byCountry.entries())
  .sort((a, b) => b[1].length - a[1].length);
---

<MainLayout
  title={`Research Institutions | ${conditionDisplayName}`}
  description={`Universities, hospitals, and research centers studying ${conditionDisplayName} worldwide`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Research Institutions</h1>
      <p class="text-lg text-gray-600">
        {institutions.length} institutions worldwide contributing to {conditionDisplayName} research
      </p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="bg-gradient-to-br from-blue-50 to-indigo-100 rounded-lg shadow-md p-6 border border-blue-200">
        <div class="text-3xl font-bold text-indigo-700">{institutions.length}</div>
        <div class="text-sm text-indigo-600 font-medium">Total Institutions</div>
      </div>
      <div class="bg-gradient-to-br from-purple-50 to-pink-100 rounded-lg shadow-md p-6 border border-purple-200">
        <div class="text-3xl font-bold text-purple-700">{countries.length}</div>
        <div class="text-sm text-purple-600 font-medium">Countries</div>
      </div>
      <div class="bg-gradient-to-br from-green-50 to-emerald-100 rounded-lg shadow-md p-6 border border-green-200">
        <div class="text-3xl font-bold text-emerald-700">
          {institutions.reduce((sum, inst) => sum + inst.conditionPapersCount, 0)}
        </div>
        <div class="text-sm text-emerald-600 font-medium">{conditionDisplayName} Publications</div>
      </div>
    </div>

    <!-- Top Institutions Table -->
    <div class="bg-white rounded-lg shadow-md overflow-hidden mb-12 border border-slate-200">
      <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-slate-50 to-gray-50">
        <h2 class="text-2xl font-bold text-gray-900">Top Institutions</h2>
        <p class="text-sm text-gray-600 mt-1">Ranked by {conditionDisplayName} publications</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rank</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Institution</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Location</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">{conditionDisplayName} Publications</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {sortedInstitutions.map((institution, idx) => (
              <tr class="hover:bg-gray-50 align-top">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  {idx + 1}
                </td>
                <td class="px-6 py-4 text-sm font-medium whitespace-normal break-words">
                  <a
                    href={`${base}institutions/${institution.id}/`}
                    class="text-primary-600 hover:text-primary-800 hover:underline"
                  >
                    {institution.name}
                  </a>
                </td>
                <td class="px-6 py-4 text-sm text-gray-600 whitespace-normal break-words">
                  {institution.city && institution.country ? (
                    <span>{institution.city}, {institution.country}</span>
                  ) : institution.country ? (
                    <span>{institution.country}</span>
                  ) : (
                    <span class="text-gray-400">—</span>
                  )}
                </td>
                <td class="px-6 py-4 text-sm text-gray-600 whitespace-normal break-words">
                  {institution.type ? (
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      {institution.type}
                    </span>
                  ) : (
                    <span class="text-gray-400">—</span>
                  )}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
                  {institution.conditionPapersCount}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- By Country -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Institutions by Country</h2>

      <div class="space-y-6">
        {countries.map(([country, insts]) => (
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
              <span>{country}</span>
              <span class="text-sm font-normal text-gray-500">
                ({insts.length} institution{insts.length !== 1 ? 's' : ''})
              </span>
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {insts.map(inst => (
                <a
                  href={`${base}institutions/${inst.id}/`}
                  class="flex items-center justify-between p-3 border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-md transition-all"
                >
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-gray-900 whitespace-normal break-words">{inst.name}</div>
                    <div class="text-sm text-gray-500">
                      {inst.conditionPapersCount} publication{inst.conditionPapersCount !== 1 ? 's' : ''}
                    </div>
                  </div>
                  <svg class="w-5 h-5 text-gray-400 flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</MainLayout>
