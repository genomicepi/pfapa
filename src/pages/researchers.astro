  <!-- Network visualization -->
  <script is:inline define:vars={{ papersWithYears, minYear, maxYear }}>
    document.addEventListener('DOMContentLoaded', function() {
      const authorsDataElement = document.getElementById('authors-data');
      const authorsData = authorsDataElement ? JSON.parse(authorsDataElement.textContent || '[]') : [];

      // Get primary color from Bootstrap CSS
      const primaryColor = getComputedStyle(document.documentElement).getPropertyValue('--bs-primary') || '#0d6efd';

      const container = document.getElementById('network');
      const description = document.getElementById('network-description');
      const legend = document.getElementById('researcher-legend');
      const toggleResearchers = document.getElementById('toggle-researchers');
      const toggleInstitutions = document.getElementById('toggle-institutions');

      // Map controls
      const mapYearSlider = document.getElementById('map-year-slider');
      const mapYearDisplay = document.getElementById('map-year-display');
      const mapPaperCount = document.getElementById('map-paper-count');
      const mapResetButton = document.getElementById('map-reset-button');
      const mapPlayButton = document.getElementById('map-play-button');

      // Network controls
      const networkYearSlider = document.getElementById('network-year-slider');
      const networkYearDisplay = document.getElementById('network-year-display');
      const networkPaperCount = document.getElementById('network-paper-count');
      const networkResetButton = document.getElementById('network-reset-button');
      const networkPlayButton = document.getElementById('network-play-button');

      let network = null;
      let currentMode = 'researchers';
      let currentResearcherData = null;
      let currentInstitutionData = null;

      // Separate state for map and network
      let mapIsPlaying = false;
      let mapPlayInterval = null;
      let networkIsPlaying = false;
      let networkPlayInterval = null;

      let map = null;
      let mapMarkers = [];

      // Client-side normalization functions
      function normalizeAuthorName(name) {
        if (!name) return '';
        const parts = name.trim().split(/\s+/);
        if (parts.length < 2) return name;
        const lastName = parts[0];
        const initials = parts.slice(1).join('');
        const cleanInitials = initials.replace(/[.\s]/g, '');
        const firstInitial = cleanInitials.charAt(0);
        return `${lastName} ${firstInitial}`;
      }

      function normalizeInstitution(affiliation) {
        if (!affiliation) return '';

        let cleaned = affiliation.replace(/Electronic address:.*$/i, '').trim();
        const parts = cleaned.split(',').map(p => p.trim());
        const genericTerms = /^(Department of|Division of|Section of|Unit of|Laboratory of|Lab of|Institute of|Center for|Centre for|Rehabilitation Research Center|Research Center|Clinical Research|School of|EA \d+|Service de|Département de|Klinik für|Servicio de)\s+/i;

        let institution = '';
        let candidates = [];

        for (let i = 0; i < Math.min(4, parts.length); i++) {
          const part = parts[i];
          if (/University|Universit[éèa]|Hospital|Medical Center|Medical Centre|Pharmaceuticals|Pharma|College|Clinic|Klinik|Academy of Sciences/i.test(part)) {
            candidates.push({ part, priority: 10, index: i });
          } else if (/Institute|Institut|Centro|Center|Centre/i.test(part)) {
            const hasProperNoun = /\b[A-Z][a-z]+(?:\s+[A-Z][a-z]+)*\s+(Institute|Institut|Center|Centre)\b/.test(part);
            if (hasProperNoun) {
              candidates.push({ part, priority: 5, index: i });
            }
          }
        }

        if (candidates.length > 0) {
          candidates.sort((a, b) => b.priority - a.priority || a.index - b.index);
          institution = candidates[0].part;
        } else if (parts.length > 0) {
          institution = parts[0];
        }

        institution = institution
          .replace(genericTerms, '')
          .replace(/\(.*?\)/g, '')
          .replace(/\s+/g, ' ')
          .replace(/[,;].*$/, '')
          .trim();

        const normalizations = {
          'Xenon Pharmaceuticals Inc': 'Xenon Pharmaceuticals',
          'Genentech Inc.': 'Genentech',
          'Yale School of Medicine': 'Yale University',
          'Yale University School of Medicine': 'Yale University',
          'Harvard Medical School': 'Harvard University',
          'Stanford University School of Medicine': 'Stanford University',
          'Boston University School of Medicine': 'Boston University',
          'University of California Los Angeles': 'UCLA',
          'University of California-Irvine': 'UC Irvine',
          'University of California San Francisco': 'UCSF',
          'Johns Hopkins University School of Medicine': 'Johns Hopkins University',
          'Mayo Clinic College of Medicine': 'Mayo Clinic',
          'Mayo Clinic School of Medicine': 'Mayo Clinic',
          'Mayo Clinic Rochester': 'Mayo Clinic',
          'Perelman School of Medicine': 'University of Pennsylvania',
          'Penn Medicine': 'University of Pennsylvania',
          'RWTH Aachen': 'RWTH Aachen University',
          'Nuffield Department of Clinical Neurosciences': 'University of Oxford',
          'Veterans Affairs Hospital': 'VA Connecticut Healthcare System',
          'Veterans Affairs Medical Center': 'VA Connecticut Healthcare System',
          'Veterans Affairs Connecticut Healthcare System': 'VA Connecticut Healthcare System',
          'Rehabilitation Research Center': 'VA Connecticut Healthcare System',
          'Rehabilitation Research': 'VA Connecticut Healthcare System',
          'Neuroscience and Regeneration Research': 'Yale University',
          'Restoration of Nervous System Function': 'VA Connecticut Healthcare System',
          'Astra-Zeneca': 'AstraZeneca',
          'Maastricht University Medical Center': 'Maastricht University',
          'Oslo University Hospital': 'University of Oslo',
          'Friedrich-Alexander-University': 'Friedrich-Alexander-Universität Erlangen-Nürnberg',
          'Friedrich-Alexander Universität': 'Friedrich-Alexander-Universität Erlangen-Nürnberg',
          'University of Washington School of Medicine': 'University of Washington',
          'Inha University School of Medicine': 'Inha University',
          'Sun Yat-sen Memorial Hospital': 'Sun Yat-sen University',
          'Peking University First Hospital': 'Peking University',
          'Peking University Third Hospital': 'Peking University',
        };

        for (const [pattern, normalized] of Object.entries(normalizations)) {
          if (institution.toLowerCase().includes(pattern.toLowerCase())) {
            return normalized;
          }
        }

        const genericDepartments = /^(Pharmacology|Neurology|Dermatology|Pediatrics|Medicine|Surgery|Anaesthesia|Anesthesiology|Pathology|Neurobiology|Rheumatology|Rhumatologie|Clinical Genetics|Clinical Pharmacology|Clinical Neurophysiology|Clinical Neurosciences|Pharmaceutical Sciences|Physiology and Pathophysiology|Internal Medicine|Hematology|Gastroenterology|Cardiology|Oncology|Radiology|for Pharmaceutical Preparations|Clinical-Surgical|Diagnostic and Pediatric Science|Internal Medicine Department)$/i;

        if (!institution || institution.length < 3 || genericDepartments.test(institution)) {
          return '';
        }

        return institution;
      }

      // Build network data from filtered papers
      function buildNetworkData(filteredPapers) {
        const authorStats = new Map();
        const coauthors = new Map();
        const institutions = new Map();

        filteredPapers.forEach(paper => {
          const authors = paper.authors || [];

          authors.forEach(authorData => {
            const authorName = typeof authorData === 'string' ? authorData : authorData.name;
            const affiliations = typeof authorData === 'object' ? (authorData.affiliations || []) : [];
            const orcid = typeof authorData === 'object' ? authorData.orcid : '';

            const normalizedName = normalizeAuthorName(authorName);

            if (!authorStats.has(normalizedName)) {
              authorStats.set(normalizedName, {
                name: normalizedName,
                originalNames: new Set([authorName]),
                papers: [],
                collaborators: new Set(),
                institutions: new Set(),
                orcid: orcid || ''
              });
            }

            const stats = authorStats.get(normalizedName);
            stats.originalNames.add(authorName);
            stats.papers.push(paper.pmid);

            if (orcid && !stats.orcid) {
              stats.orcid = orcid;
            }

            affiliations.forEach(affiliation => {
              const normalizedInst = normalizeInstitution(affiliation);
              if (normalizedInst) {
                stats.institutions.add(normalizedInst);
                institutions.set(normalizedInst, (institutions.get(normalizedInst) || 0) + 1);
              }
            });
          });

          // Track co-author relationships
          for (let i = 0; i < authors.length; i++) {
            for (let j = i + 1; j < authors.length; j++) {
              const name1 = typeof authors[i] === 'string' ? authors[i] : authors[i].name;
              const name2 = typeof authors[j] === 'string' ? authors[j] : authors[j].name;

              const author1 = normalizeAuthorName(name1);
              const author2 = normalizeAuthorName(name2);

              if (author1 === author2) continue;

              const pair = [author1, author2].sort().join('|||');
              coauthors.set(pair, (coauthors.get(pair) || 0) + 1);

              authorStats.get(author1).collaborators.add(author2);
              authorStats.get(author2).collaborators.add(author1);
            }
          }
        });

        // Enrich with OpenAlex institution data
        authorsData.forEach(author => {
          author.variants.forEach(variant => {
            const normalized = normalizeAuthorName(variant);
            const stats = authorStats.get(normalized);

            if (stats && author.currentAffiliation) {
              stats.institutions.add(author.currentAffiliation);
            }
          });
        });

        const researchers = Array.from(authorStats.values())
          .map(r => ({
            name: r.name,
            publications: r.papers.length,
            collaborators: r.collaborators.size,
            papers: r.papers,
            institutions: Array.from(r.institutions),
            orcid: r.orcid
          }))
          .sort((a, b) => b.publications - a.publications);

        const topInstitutions = Array.from(institutions.entries())
          .map(([name, count]) => ({ name, count }))
          .sort((a, b) => b.count - a.count)
          .slice(0, 20);

        // Build researcher network
        const topResearchers = researchers.slice(0, 50);
        const topNames = new Set(topResearchers.map(r => r.name));

        // Dynamic color palette for institutions (based on rank) - colorblind-friendly, distinct colors
        const colorPalette = ['#0d9488', '#3b82f6', '#f59e0b', '#8b5cf6', '#ec4899', '#14b8a6', '#6366f1', '#d97706', '#a855f7'];
        const institutionColors = {};
        topInstitutions.forEach((inst, idx) => {
          institutionColors[inst.name] = colorPalette[idx % colorPalette.length];
        });

        const researcherNodes = topResearchers.map((r, idx) => {
          const primaryInst = r.institutions[0] || '';
          const color = institutionColors[primaryInst] || '#4b5563';

          return {
            id: idx,
            label: r.name,
            value: r.publications,
            title: `${r.name}\n${r.publications} papers\n${r.collaborators} collaborators${primaryInst ? '\n' + primaryInst : ''}`,
            color: {
              background: color,
              border: color,
              highlight: { background: color, border: '#1f2937' }
            }
          };
        });

        const researcherEdges = [];
        coauthors.forEach((count, pair) => {
          const [author1, author2] = pair.split('|||');
          if (topNames.has(author1) && topNames.has(author2)) {
            const id1 = topResearchers.findIndex(r => r.name === author1);
            const id2 = topResearchers.findIndex(r => r.name === author2);
            researcherEdges.push({
              from: id1,
              to: id2,
              value: count,
              title: `${count} collaboration${count > 1 ? 's' : ''}`
            });
          }
        });

        // Build institution network
        const institutionCollabs = new Map();
        filteredPapers.forEach(paper => {
          const authors = paper.authors || [];
          const paperInstitutions = new Set();

          authors.forEach(authorData => {
            const affiliations = typeof authorData === 'object' ? (authorData.affiliations || []) : [];
            affiliations.forEach(affiliation => {
              const inst = normalizeInstitution(affiliation);
              if (inst) paperInstitutions.add(inst);
            });
          });

          const instArray = Array.from(paperInstitutions);
          for (let i = 0; i < instArray.length; i++) {
            for (let j = i + 1; j < instArray.length; j++) {
              const pair = [instArray[i], instArray[j]].sort().join('|||');
              institutionCollabs.set(pair, (institutionCollabs.get(pair) || 0) + 1);
            }
          }
        });

        const topInsts = topInstitutions.slice(0, 40);
        const topInstNames = new Set(topInsts.map(i => i.name));

        const institutionNodes = topInsts.map((inst, idx) => ({
          id: idx,
          label: inst.name,
          value: inst.count,
          title: `${inst.name}\n${inst.count} publication${inst.count > 1 ? 's' : ''}`
        }));

        const institutionEdges = [];
        institutionCollabs.forEach((count, pair) => {
          const [inst1, inst2] = pair.split('|||');
          if (topInstNames.has(inst1) && topInstNames.has(inst2)) {
            const id1 = topInsts.findIndex(i => i.name === inst1);
            const id2 = topInsts.findIndex(i => i.name === inst2);
            institutionEdges.push({
              from: id1,
              to: id2,
              value: count,
              title: `${count} shared publication${count > 1 ? 's' : ''}`
            });
          }
        });

        return {
          researcherNetworkData: { nodes: researcherNodes, edges: researcherEdges },
          institutionNetworkData: { nodes: institutionNodes, edges: institutionEdges }
        };
      }

      // Map functions and data
      const countryCoords = {
        'United States': [37.0902, -95.7129],
        'USA': [37.0902, -95.7129],
        'China': [35.8617, 104.1954],
        'Japan': [36.2048, 138.2529],
        'United Kingdom': [55.3781, -3.4360],
        'UK': [55.3781, -3.4360],
        'Germany': [51.1657, 10.4515],
        'France': [46.2276, 2.2137],
        'Italy': [41.8719, 12.5674],
        'Spain': [40.4637, -3.7492],
        'Canada': [56.1304, -106.3468],
        'Australia': [-25.2744, 133.7751],
        'Netherlands': [52.1326, 5.2913],
        'Switzerland': [46.8182, 8.2275],
        'Sweden': [60.1282, 18.6435],
        'Norway': [60.4720, 8.4689],
        'Denmark': [56.2639, 9.5018],
        'Belgium': [50.5039, 4.4699],
        'Austria': [47.5162, 14.5501],
        'South Korea': [35.9078, 127.7669],
        'Korea': [35.9078, 127.7669],
        'Taiwan': [23.6978, 120.9605],
        'India': [20.5937, 78.9629],
        'Brazil': [-14.2350, -51.9253],
        'Mexico': [23.6345, -102.5528],
        'Argentina': [-38.4161, -63.6167],
        'Israel': [31.0461, 34.8516],
        'Turkey': [38.9637, 35.2433],
        'Poland': [51.9194, 19.1451],
        'Czech Republic': [49.8175, 15.4730],
        'Czechia': [49.8175, 15.4730],
        'Ireland': [53.4129, -8.2439],
        'New Zealand': [-40.9006, 174.8860],
        'Singapore': [1.3521, 103.8198],
        'Finland': [61.9241, 25.7482],
        'Greece': [39.0742, 21.8243],
        'Portugal': [39.3999, -8.2245],
        'Russia': [61.5240, 105.3188],
        'South Africa': [-30.5595, 22.9375],
        'Egypt': [26.8206, 30.8025],
        'Iran': [32.4279, 53.6880],
        'Thailand': [15.8700, 100.9925],
        'Vietnam': [14.0583, 108.2772],
        'Pakistan': [30.3753, 69.3451],
        'Saudi Arabia': [23.8859, 45.0792],
        'Chile': [-35.6751, -71.5430],
        'Colombia': [4.5709, -74.2973],
        'Romania': [45.9432, 24.9668],
        'Hungary': [47.1625, 19.5033],
        'Croatia': [45.1, 15.2]
      };

      function extractLocationsFromPapers(papers) {
        const locations = new Map();
        const usStates = new Set([
          'Alabama', 'Alaska', 'Arizona', 'Arkansas', 'California', 'Colorado',
          'Connecticut', 'Delaware', 'Florida', 'Georgia', 'Hawaii', 'Idaho',
          'Illinois', 'Indiana', 'Iowa', 'Kansas', 'Kentucky', 'Louisiana',
          'Maine', 'Maryland', 'Massachusetts', 'Michigan', 'Minnesota',
          'Mississippi', 'Missouri', 'Montana', 'Nebraska', 'Nevada',
          'New Hampshire', 'New Jersey', 'New Mexico', 'New York',
          'North Carolina', 'North Dakota', 'Ohio', 'Oklahoma', 'Oregon',
          'Pennsylvania', 'Rhode Island', 'South Carolina', 'South Dakota',
          'Tennessee', 'Texas', 'Utah', 'Vermont', 'Virginia', 'Washington',
          'West Virginia', 'Wisconsin', 'Wyoming', 'DC', 'District of Columbia'
        ]);

        papers.forEach(paper => {
          const authors = paper.authors || [];
          authors.forEach(authorData => {
            const affiliations = typeof authorData === 'object' ? (authorData.affiliations || []) : [];
            affiliations.forEach(affiliation => {
              let location = null;
              let match = affiliation.match(/,\s*[A-Z]{2}\s*,\s*([A-Z][a-z]+(?:\s+[A-Z][a-z]+)*)\.?\s*$/);
              if (match) {
                location = match[1].trim();
              } else {
                match = affiliation.match(/,\s*([A-Z][a-z]+(?:\s+[A-Z][a-z]+)*)\.?\s*$/);
                if (match) {
                  const candidate = match[1].trim();
                  if (!usStates.has(candidate)) {
                    location = candidate;
                  } else {
                    location = 'United States';
                  }
                }
              }

              if (location) {
                const countryMap = {
                  'USA': 'United States',
                  'UK': 'United Kingdom',
                  'P.R. China': 'China',
                  'PR China': 'China',
                  "People's Republic of China": 'China',
                  'The Netherlands': 'Netherlands',
                };
                location = countryMap[location] || location;
                locations.set(location, (locations.get(location) || 0) + 1);
              }
            });
          });
        });

        return Array.from(locations.entries())
          .map(([name, count]) => ({ name, count }))
          .sort((a, b) => b.count - a.count);
      }

      function initMap() {
        if (!map) {
          map = L.map('map').setView([20, 0], 2);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 18
          }).addTo(map);
        }
      }

      function updateMap(filteredPapers) {
        // Clear existing markers
        mapMarkers.forEach(marker => marker.remove());
        mapMarkers = [];

        // Extract locations from filtered papers
        const topLocations = extractLocationsFromPapers(filteredPapers);

        // Add new markers
        topLocations.forEach(loc => {
          const coords = countryCoords[loc.name];
          if (coords) {
            const radius = Math.sqrt(loc.count) * 3;
            const marker = L.circleMarker(coords, {
              radius: radius,
              fillColor: primaryColor,
              color: primaryColor,
              weight: 2,
              opacity: 0.8,
              fillOpacity: 0.5
            })
            .bindPopup(`<strong>${loc.name}</strong><br>${loc.count} publication${loc.count > 1 ? 's' : ''}`)
            .addTo(map);
            mapMarkers.push(marker);
          }
        });
      }

      const options = {
        nodes: {
          shape: 'dot',
          scaling: {
            min: 10,
            max: 40,
            label: {
              enabled: true,
              min: 32,
              max: 40
            }
          },
          font: {
            size: 32,
            color: '#1f2937',
            face: 'system-ui, -apple-system, sans-serif',
            strokeWidth: 4,
            strokeColor: '#ffffff',
            bold: true
          }
        },
        edges: {
          color: {
            color: '#d1d5db',
            highlight: '#9ca3af'
          },
          width: 1,
          scaling: {
            min: 1,
            max: 5
          },
          smooth: {
            type: 'continuous'
          }
        },
        physics: {
          forceAtlas2Based: {
            gravitationalConstant: -50,
            centralGravity: 0.001,
            springLength: 300,
            springConstant: 0.12
          },
          maxVelocity: 146,
          solver: 'forceAtlas2Based',
          timestep: 0.35,
          stabilization: {
            enabled: true,
            iterations: 200
          }
        },
        interaction: {
          hover: true,
          tooltipDelay: 200,
          navigationButtons: true,
          keyboard: true
        }
      };

      function initNetwork(data) {
        if (network) {
          network.destroy();
        }
        network = new vis.Network(container, data, options);

        network.on('stabilizationProgress', function(params) {
          const progress = Math.round((params.iterations / params.total) * 100);
          console.log('Loading network: ' + progress + '%');
        });

        network.on('stabilizationIterationsDone', function() {
          console.log('Network visualization ready');
        });
      }

      // Map year filter handler
      function updateMapYearFilter() {
        const selectedYear = parseInt(mapYearSlider.value);

        // Cumulative: show all papers UP TO selected year
        const filteredPapers = papersWithYears.filter(p =>
          p.year && p.year <= selectedYear
        );

        if (selectedYear === maxYear) {
          mapYearDisplay.textContent = `${minYear}–${maxYear} (all time)`;
        } else {
          mapYearDisplay.textContent = `${minYear}–${selectedYear}`;
        }
        mapPaperCount.textContent = `${filteredPapers.length} papers through ${selectedYear}`;

        updateMap(filteredPapers);
      }

      // Network year filter handler
      function updateNetworkYearFilter() {
        const selectedYear = parseInt(networkYearSlider.value);

        const filteredPapers = papersWithYears.filter(p =>
          p.year && p.year >= selectedYear
        );

        if (selectedYear === minYear) {
          networkYearDisplay.textContent = `All years (${minYear}–${maxYear})`;
        } else {
          networkYearDisplay.textContent = `${selectedYear}–${maxYear}`;
        }
        networkPaperCount.textContent = `${filteredPapers.length} papers from ${selectedYear} onwards`;

        const networkData = buildNetworkData(filteredPapers);
        currentResearcherData = networkData.researcherNetworkData;
        currentInstitutionData = networkData.institutionNetworkData;

        if (currentMode === 'researchers') {
          initNetwork(currentResearcherData);
        } else {
          initNetwork(currentInstitutionData);
        }
      }

      // Map play/pause
      function toggleMapPlay() {
        if (mapIsPlaying) {
          stopMapPlayback();
        } else {
          startMapPlayback();
        }
      }

      function startMapPlayback() {
        // Start from beginning if already at the end
        if (parseInt(mapYearSlider.value) === maxYear) {
          mapYearSlider.value = minYear;
          updateMapYearFilter();
        }

        mapIsPlaying = true;
        mapPlayButton.innerHTML = '⏸ Pause';
        mapPlayButton.classList.remove('bg-primary-600', 'hover:bg-primary-700');
        mapPlayButton.classList.add('bg-gray-600', 'hover:bg-gray-700');

        mapPlayInterval = setInterval(() => {
          const currentYear = parseInt(mapYearSlider.value);
          if (currentYear < maxYear) {
            mapYearSlider.value = currentYear + 1;
            updateMapYearFilter();
          } else {
            stopMapPlayback();
          }
        }, 500); // Faster animation - 500ms per year
      }

      function stopMapPlayback() {
        mapIsPlaying = false;
        mapPlayButton.innerHTML = '▶ Play';
        mapPlayButton.classList.add('bg-primary-600', 'hover:bg-primary-700');
        mapPlayButton.classList.remove('bg-gray-600', 'hover:bg-gray-700');

        if (mapPlayInterval) {
          clearInterval(mapPlayInterval);
          mapPlayInterval = null;
        }
      }

      // Network play/pause
      function toggleNetworkPlay() {
        if (networkIsPlaying) {
          stopNetworkPlayback();
        } else {
          startNetworkPlayback();
        }
      }

      function startNetworkPlayback() {
        networkIsPlaying = true;
        networkPlayButton.innerHTML = '⏸ Pause';
        networkPlayButton.classList.remove('bg-primary-600', 'hover:bg-primary-700');
        networkPlayButton.classList.add('bg-gray-600', 'hover:bg-gray-700');

        networkPlayInterval = setInterval(() => {
          const currentYear = parseInt(networkYearSlider.value);
          if (currentYear < maxYear) {
            networkYearSlider.value = currentYear + 1;
            updateNetworkYearFilter();
          } else {
            stopNetworkPlayback();
          }
        }, 1000);
      }

      function stopNetworkPlayback() {
        networkIsPlaying = false;
        networkPlayButton.innerHTML = '▶ Play';
        networkPlayButton.classList.add('bg-primary-600', 'hover:bg-primary-700');
        networkPlayButton.classList.remove('bg-gray-600', 'hover:bg-gray-700');

        if (networkPlayInterval) {
          clearInterval(networkPlayInterval);
          networkPlayInterval = null;
        }
      }

      function switchToResearchers() {
        currentMode = 'researchers';
        toggleResearchers.classList.add('bg-primary-600', 'text-white');
        toggleResearchers.classList.remove('text-gray-600', 'hover:text-gray-900');
        toggleInstitutions.classList.remove('bg-primary-600', 'text-white');
        toggleInstitutions.classList.add('text-gray-600', 'hover:text-gray-900');
        description.textContent = 'Top 50 researchers by publication count. Node size = publications, edge thickness = collaborations. Colors indicate institutional affiliation.';
        legend.style.display = 'flex';
        initNetwork(currentResearcherData);
      }

      function switchToInstitutions() {
        currentMode = 'institutions';
        toggleInstitutions.classList.add('bg-primary-600', 'text-white');
        toggleInstitutions.classList.remove('text-gray-600', 'hover:text-gray-900');
        toggleResearchers.classList.remove('bg-primary-600', 'text-white');
        toggleResearchers.classList.add('text-gray-600', 'hover:text-gray-900');
        description.textContent = 'Top 40 institutions by publication count. Node size = publications, edges = shared papers.';
        legend.style.display = 'none';
        initNetwork(currentInstitutionData);
      }

      // Map event listeners
      mapYearSlider.addEventListener('input', () => {
        if (mapIsPlaying) stopMapPlayback();
        updateMapYearFilter();
      });

      mapResetButton.addEventListener('click', function() {
        stopMapPlayback();
        mapYearSlider.value = maxYear;
        updateMapYearFilter();
      });

      mapPlayButton.addEventListener('click', toggleMapPlay);

      // Network event listeners
      networkYearSlider.addEventListener('input', () => {
        if (networkIsPlaying) stopNetworkPlayback();
        updateNetworkYearFilter();
      });

      networkResetButton.addEventListener('click', function() {
        stopNetworkPlayback();
        networkYearSlider.value = minYear;
        updateNetworkYearFilter();
      });

      networkPlayButton.addEventListener('click', toggleNetworkPlay);

      toggleResearchers.addEventListener('click', switchToResearchers);
      toggleInstitutions.addEventListener('click', switchToInstitutions);

      // Initialize
      initMap();
      updateMapYearFilter();
      updateNetworkYearFilter();
      switchToResearchers();
    });
  </script>
</MainLayout>
