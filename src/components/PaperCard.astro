---
import type { Paper } from '../lib/types';

interface Props {
  paper: Paper;
}

const { paper } = Astro.props;

// Extract author names (handle both old string[] and new Author[] formats)
const authorNames = paper.authors.map(a => typeof a === 'string' ? a : a.name);

// Format date
const formatDate = (dateStr: string) => {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch {
    return dateStr;
  }
};

// Truncate abstract for preview
const truncateAbstract = (text: string, maxLength = 300) => {
  if (text.length <= maxLength) return text;
  return text.substring(0, maxLength).trim() + '...';
};

---

<div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm hover:shadow-md transition">
  <!-- Title & Evidence Badge -->
  <div class="flex justify-between items-start mb-3">
    <h3 class="text-lg font-bold text-gray-900 flex-1 mr-4">
      <a href={paper.pubmedUrl} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 hover:underline">
        {paper.title}
      </a>
    </h3>
  </div>

  <!-- Metadata -->
  <p class="text-sm text-gray-600 mb-3">
    <span class="font-medium">{authorNames.slice(0, 3).join(', ')}</span>
    {authorNames.length > 3 && `, et al.`}
    <span class="mx-2">•</span>
    <span class="italic">{paper.journal}</span>
    <span class="mx-2">•</span>
    <time datetime={paper.pubDate}>{formatDate(paper.pubDate)}</time>
  </p>

  <!-- MeSH Terms -->
  {paper.meshTerms.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {paper.meshTerms.slice(0, 5).map(term => (
        <span class="px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded">
          {term}
        </span>
      ))}
      {paper.meshTerms.length > 5 && (
        <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">
          +{paper.meshTerms.length - 5} more
        </span>
      )}
    </div>
  )}

  <!-- Abstract Preview -->
  {paper.abstract && paper.abstract !== 'No abstract available' && (
    <div class="mb-4">
      <p class="text-sm text-gray-700 leading-relaxed">
        {truncateAbstract(paper.abstract)}
      </p>
    </div>
  )}

  <!-- Footer Actions -->
  <div class="flex justify-between items-center pt-3 border-t border-gray-200">
    <a
      href={paper.pubmedUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-primary-600 hover:text-primary-700 font-medium"
    >
      View on PubMed →
    </a>
    {paper.doi && (
      <a
        href={`https://doi.org/${paper.doi}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-gray-500 hover:text-gray-700"
      >
        DOI: {paper.doi}
      </a>
    )}
  </div>
</div>
