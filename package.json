{
  "name": "researchnet-template",
  "type": "module",
  "version": "0.1.0",
  "description": "Template for creating public research databases for any medical condition",
  "keywords": [
    "research",
    "pubmed",
    "clinical-trials",
    "medical",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/genomicepi/researchnet-template"
  },
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch-data": "npm run fetch-pubmed && npm run fetch-trials && npm run build-profiles",
    "fetch-pubmed": "node scripts/fetch-pubmed.js",
    "fetch-trials": "node scripts/fetch-clinical-trials.js",
    "build-profiles": "node scripts/build-openalex-profiles.js",
    "validate-config": "node scripts/validate-config.js"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.2",
    "astro": "^5.1.3",
    "tailwindcss": "^3.4.17",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "yaml": "^2.8.3"
  }
}
